        "_notes": {
          "value_x_offset": "Label ke baad value kitne pixels pe start hoga (80 = tight spacing, 180 = loose)",
          "line_height": "Har line ki height in pixels"
        },
        "fields_normal_order": [
          {
            "key": "customer_name",
            "label": "To:",
            "show": true,
            "highlight": false,
            "order": 1
          },
          {
            "key": "customer_phone",
            "label": "Phone No:",
            "show": true,
            "highlight": false,
            "order": 2
          },
          {
            "key": "delivery_address",
            "label": "Address:",
            "show": true,
            "highlight": false,
