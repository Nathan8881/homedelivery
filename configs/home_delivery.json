          {
            "key": "delivery_address",
            "label": "Address:",
            "show": true,
            "highlight": false,
            "order": 3
          },
          {
            "key": "customer_name_phone",
            "label": "Order by:",
            "show": true,
            "highlight": false,
            "order": 4,
            "combined_format": "{customer_name} | {customer_phone}"
          },
          {
            "key": "courier_note",
            "label": "Note for courier:",
            "show": true,
            "highlight": false,
            "order": 5
          }
        ]
      },

      "recommendation": {
        "enabled": true,
