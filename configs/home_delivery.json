  "fields": {
    "invoice_no": {
      "jotform_field": "q44_invoiceId",
      "field_type": "text"
    },
    "customer_name": {
      "jotform_field": "q1_yourName",
      "field_type": "name_object"
    },
    "customer_phone": {
      "jotform_field": "q19_yourPhone",
      "field_type": "text"
    },
    "customer_email": {
      "jotform_field": "q2_yourEmail",
      "field_type": "text"
    },
    "delivery_address": {
      "jotform_field": "q3_deliveryAddress3",
      "field_type": "address_object"
    },
    "delivery_address_line1": {
      "jotform_field": "q3_deliveryAddress3",
      "field_type": "address_line1"
    },
    "delivery_address_line2": {
      "jotform_field": "q3_deliveryAddress3",
      "field_type": "address_line2"
    },
    "delivery_suburb": {
      "jotform_field": "q3_deliveryAddress3",
      "field_type": "address_suburb"
    },
    "delivery_state": {
      "jotform_field": "q3_deliveryAddress3",
      "field_type": "address_state"
    },
    "delivery_postcode": {
